      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>SUSTANCIA NIGRA</size></b><br><br> <b>Generalidades:</b>
        N\xFAcleo mesencef\xE1lico dividido en dos porciones: pars compacta, rica
        en neuronas dopamin\xE9rgicas pigmentadas, y pars reticulata, una regi\xF3n
        GABA\xE9rgica que funciona como salida inhibitoria de los ganglios basales.
        Participa en el control del movimiento, el aprendizaje motor y la selecci\xF3n
        de acciones.<br><br> <b>Principales aferencias:</b> Estriado mediante proyecciones
        GABA\xE9rgicas hacia ambas porciones; corteza cerebral mediante proyecciones
        glutamat\xE9rgicas; n\xFAcleo subtal\xE1mico; proyecciones moduladoras provenientes
        del tronco encef\xE1lico.<br><br> <b>Principales eferencias:</b> La pars
        compacta proyecta al estriado mediante v\xEDas dopamin\xE9rgicas que modulan
        las v\xEDas directa e indirecta; la pars reticulata env\xEDa proyecciones
        inhibitorias hacia el t\xE1lamo ventral, el col\xEDculo superior y n\xFAcleos
        reticulares.<br><br><br>"
      objectReference: {fileID: 0}
    - target: {fileID: 7264986227520560567, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: m_Name
