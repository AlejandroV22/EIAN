    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: temaID
      value: puente
      objectReference: {fileID: 0}
    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: zonaID
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>N\xDACLEO MESENCEF\xC1LICO DEL TRIG\xC9MINO</size></b><br><br>
        <b>Generalidades:</b> Grupo de neuronas sensoriales pseudounipolares ubicado
        dentro del mesenc\xE9falo. Es \xFAnico porque funciona como un ganglio propioceptivo
        dentro del sistema nervioso central. Procesa la propiocepci\xF3n de los m\xFAsculos
        de la masticaci\xF3n y estructuras asociadas para regular la fuerza de mordida
        y el tono mandibular.<br><br> <b>Principales aferencias:</b> Husos neuromusculares
        de los m\xFAsculos masticatorios; receptores del periodonto que detectan
        presi\xF3n dental.<br><br> <b>Principales eferencias:</b> Proyecciones hacia
        el n\xFAcleo motor del trig\xE9mino (reflejo maseterino); conexiones con
        el cerebelo (coordinaci\xF3n de la masticaci\xF3n) y con la formaci\xF3n
        reticular (regulaci\xF3n del tono mandibular).<br><br><br>"
      objectReference: {fileID: 0}
    - target: {fileID: 7264986227520560567, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: m_Name
      value: Seccion3 (8)
      objectReference: {fileID: 0}
    - target: {fileID: 7264986227520560567, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: m_IsActive
