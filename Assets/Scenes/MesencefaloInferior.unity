    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>PED\xDANCULO CEREBELOSO SUPERIOR</size></b><br><br> <b>Generalidades:</b>
        Haz de fibras que conecta el cerebelo con la porci\xF3n rostral de la protuberancia
        y el mesenc\xE9falo. Constituye la principal v\xEDa eferente del cerebelo
        y transporta se\xF1ales relacionadas con la planificaci\xF3n y coordinaci\xF3n
        del movimiento.<br><br> <b>Principales aferencias:</b> Algunas fibras espinocerebelosas
        y conexiones procedentes de estructuras del tronco encef\xE1lico.<br><br>
        <b>Principales eferencias:</b> Fibras provenientes de los n\xFAcleos profundos
        del cerebelo, especialmente el n\xFAcleo dentado, que se proyectan hacia
        el t\xE1lamo y otras estructuras motoras del tronco encef\xE1lico.<br><br><br>"
      objectReference: {fileID: 0}
    - target: {fileID: 7264986227520560567, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: m_Name
      value: Seccion3
      objectReference: {fileID: 0}
