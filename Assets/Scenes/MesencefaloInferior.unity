    - target: {fileID: 5597142459016686881, guid: b695782af0fcf0e40ac8d6228e207b3a, type: 3}
      propertyPath: panel
      value: 
      objectReference: {fileID: 140399504}
    - target: {fileID: 5597142459016686881, guid: b695782af0fcf0e40ac8d6228e207b3a, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>VELO MEDULAR SUPERIOR</size></b><br><br> <b>Generalidades:</b>
        Delgada l\xE1mina de sustancia blanca que forma parte del techo del cuarto
        ventr\xEDculo, situada por encima de los ped\xFAnculos cerebelosos superiores.
        Conecta ambos hemisferios cerebelosos en su porci\xF3n superior y sirve como
        superficie por donde discurren fibras relacionadas con la coordinaci\xF3n
        motora. En su cara dorsal se originan los frenillos del velo medular superior.<br><br>
        <b>Principales aferencias:</b> Fibras provenientes de estructuras cerebelosas
        y del tronco encef\xE1lico que participan en circuitos de coordinaci\xF3n
        motora.<br><br> <b>Principales eferencias:</b> Conexiones hacia estructuras
        cerebelosas y v\xEDas que participan en la integraci\xF3n motora dentro del
        tronco encef\xE1lico.<br><br><br>"
      objectReference: {fileID: 0}
    - target: {fileID: 7264986227520560567, guid: b695782af0fcf0e40ac8d6228e207b3a, type: 3}
      propertyPath: m_Name
      value: CurvaUI
      objectReference: {fileID: 0}
    - target: {fileID: 9162815392540484975, guid: b695782af0fcf0e40ac8d6228e207b3a, type: 3}
      propertyPath: m_Pivot.x
      value: 0.5
