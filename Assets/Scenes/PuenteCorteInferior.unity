    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>N\xDACLEOS PONTINOS</size></b><br><br> <b>Generalidades:</b>
        Conjunto de n\xFAcleos situados en la base del puente que reciben informaci\xF3n
        procedente de la corteza cerebral y la retransmiten al cerebelo. Constituyen
        un centro clave para la coordinaci\xF3n motora, planificaci\xF3n y correcci\xF3n
        del movimiento voluntario.<br><br> <b>Principales aferencias:</b> Corteza
        cerebral a trav\xE9s de fibras corticopontinas procedentes de \xE1reas motoras,
        premotoras, somatosensoriales y asociativas.<br><br> <b>Principales eferencias:</b>
        Fibras pontocerebelosas que cruzan la l\xEDnea media y entran al cerebelo
        contralateral por el ped\xFAnculo cerebeloso medio, llevando se\xF1ales necesarias
        para la coordinaci\xF3n del movimiento voluntario.<br><br><br>"
      objectReference: {fileID: 0}
