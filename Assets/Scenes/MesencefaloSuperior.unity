    - target: {fileID: 5597142459016686881, guid: b695782af0fcf0e40ac8d6228e207b3a, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>FIBRAS FRONTO-PONTINAS</size></b><br><br> <b>Generalidades:</b>
        Proyecciones corticopontinas que se originan en la corteza frontal y descienden
        hacia los n\xFAcleos pontinos para participar en circuitos de coordinaci\xF3n
        motora a trav\xE9s del cerebelo.<br><br> <b>Principales aferencias:</b> Corteza
        frontal, especialmente \xE1reas motoras, premotoras y de asociaci\xF3n frontal.<br><br>
        <b>Principales eferencias:</b> N\xFAcleos pontinos, desde donde la informaci\xF3n
        contin\xFAa hacia el cerebelo mediante fibras pontocerebelosas.<br><br><br>"
      objectReference: {fileID: 0}
