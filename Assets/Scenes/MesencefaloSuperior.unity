    - target: {fileID: 5597142459016686881, guid: b695782af0fcf0e40ac8d6228e207b3a, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>FIBRAS TEMPORO-PARIETO-OCCIPITO-PONTINAS</size></b><br><br>
        <b>Generalidades:</b> Proyecciones corticopontinas originadas en las \xE1reas
        temporales, parietales y occipitales que descienden por la c\xE1psula interna
        hacia los n\xFAcleos pontinos. Transmiten al cerebelo informaci\xF3n sensorial,
        espacial y asociativa relacionada con audici\xF3n, visi\xF3n e integraci\xF3n
        multisensorial.<br><br> <b>Principales aferencias:</b> Corteza temporal,
        parietal y occipital, especialmente \xE1reas de asociaci\xF3n sensorial.<br><br>
        <b>Principales eferencias:</b> N\xFAcleos pontinos, desde donde la informaci\xF3n
        contin\xFAa hacia la corteza cerebelosa a trav\xE9s del ped\xFAnculo cerebeloso
        medio, permitiendo que el cerebelo ajuste los movimientos voluntarios usando
        informaci\xF3n sensorial compleja.<br><br><br>"
      objectReference: {fileID: 0}
    - target: {fileID: 7264986227520560567, guid: b695782af0fcf0e40ac8d6228e207b3a, type: 3}
      propertyPath: m_Name
