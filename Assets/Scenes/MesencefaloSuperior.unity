      objectReference: {fileID: 512309976}
    - target: {fileID: 5597142459016686881, guid: b695782af0fcf0e40ac8d6228e207b3a, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>FIBRAS CORTICOESPINALES Y CORTICONUCLEARES</size></b><br><br>
        <b>Generalidades:</b> V\xEDas motoras descendentes que parten de la corteza
        motora y descienden juntas por la corona radiada y la c\xE1psula interna.
        Permiten el control voluntario del movimiento tanto del cuerpo como de la
        cabeza.<br><br> <b>Principales aferencias:</b> Corteza motora primaria y
        \xE1reas motoras asociadas.<br><br> <b>Principales eferencias:</b> Las fibras
        corticoespinales descienden por el tronco encef\xE1lico y la m\xE9dula espinal
        para sinaptar con interneuronas y motoneuronas que controlan m\xFAsculos
        del tronco y las extremidades; las fibras corticonucleares se desv\xEDan
        hacia los n\xFAcleos motores de los nervios craneales para controlar movimientos
        voluntarios de cara, ojos, mand\xEDbula y musculatura orofar\xEDngea.<br><br><br>"
      objectReference: {fileID: 0}
    - target: {fileID: 7264986227520560567, guid: b695782af0fcf0e40ac8d6228e207b3a, type: 3}
      propertyPath: m_Name
