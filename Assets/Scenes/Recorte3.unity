    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>N\xDACLEO DORSAL DEL VAGO</size></b><br><br>  <b>Generalidades:</b>
        N\xFAcleo motor parasimp\xE1tico que controla funciones aut\xF3nomas de v\xEDsceras
        tor\xE1cicas y abdominales hasta el colon transverso.<br><br>  <b>Principales
        aferencias:</b> N\xFAcleo del tracto solitario e hipot\xE1lamo por el fasc\xEDculo
        longitudinal dorsal.<br><br>  <b>Principales eferencias:</b> Ganglios intramurales
        del t\xF3rax y abdomen hasta el colon transverso.<br><br><br>"
      objectReference: {fileID: 0}
