    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>N\xDACLEO GR\xC1CIL</size></b><br><br>  <b>Generalidades:</b>
        N\xFAcleo del bulbo raqu\xEDdeo donde terminan las fibras del fasc\xEDculo
        gr\xE1cil que conducen sensibilidad fina, vibraci\xF3n y propiocepci\xF3n
        consciente de T7 hacia abajo.<br><br>  <b>Principales aferencias:</b> Neuronas
        pseudounipolares de la m\xE9dula espinal.<br><br>  <b>Principales eferencias:</b>
        Fibras arcuatas internas que se decusan en el bulbo y ascienden como lemnisco
        medial hacia el VPL del t\xE1lamo.<br><br><br>"
      objectReference: {fileID: 0}
