    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>SISTEMA ANTEROLATERAL</size></b><br><br>  <b>Generalidades:</b>
        Tracto encargado de transmitir sensaciones de dolor, temperatura y tacto
        grosero desde el lado contralateral del cuerpo, tras decusarse en la m\xE9dula
        espinal.<br><br>  <b>Principales aferencias:</b> L\xE1mina II de Rexed en
        el asta posterior de la m\xE9dula espinal.<br><br>  <b>Principales eferencias:</b>
        N\xFAcleo ventral posterolateral del t\xE1lamo ipsilateral.<br><br><br>"
      objectReference: {fileID: 0}
    - target: {fileID: 7264986227520560567, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
