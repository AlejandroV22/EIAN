      propertyPath: infoTexto
      value: "<b><size=120%>TRACTO TECTOESPINAL</size></b><br><br>  <b>Generalidades:</b>
        Tracto descendente que se origina en los col\xEDculos superiores y coordina
        movimientos reflejos de cabeza y cuello ante est\xEDmulos visuales y auditivos.<br><br> 
        <b>Principales aferencias:</b> Col\xEDculos superiores contralaterales (reciben
        informaci\xF3n visual, auditiva y somatosensorial).<br><br>  <b>Principales
        eferencias:</b> Asta anterior de la m\xE9dula espinal cervical.<br><br><br>"
      objectReference: {fileID: 0}
