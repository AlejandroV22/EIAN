      value: "<b><size=120%>PIR\xC1MIDES BULBARES</size></b><br><br> <b>Generalidades:</b>
        Formadas por el fasc\xEDculo corticoespinal que desciende desde la corteza
        motora primaria (\xE1rea 4).<br><br> <b>Principales aferencias:</b> Corteza
        motora primaria (\xE1rea 4 de Brodmann).<br><br> <b>Principales eferencias:</b>
        Asta anterior de la m\xE9dula espinal (l\xE1minas VIII y IX de Rexed).<br><br><br>"
      objectReference: {fileID: 0}
