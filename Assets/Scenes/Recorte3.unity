    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>N\xDACLEO MOTOR DEL HIPOGLOSO (XII)</size></b><br><br> 
        <b>Generalidades:</b> N\xFAcleo motor som\xE1tico que inerva los m\xFAsculos
        intr\xEDnsecos y extr\xEDnsecos de la lengua, controlando sus movimientos
        voluntarios y reflejos.<br><br>  <b>Principales aferencias:</b> Corteza motora
        contralateral por v\xEDa corticobulbar.<br><br>  <b>Principales eferencias:</b>
        Nervio hipogloso hacia m\xFAsculos de la lengua (excepto palatogloso).<br><br><br>"
      objectReference: {fileID: 0}
