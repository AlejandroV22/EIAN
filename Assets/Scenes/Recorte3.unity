      propertyPath: infoTexto
      value: "<b><size=120%>FASC\xCDCULO LONGITUDINAL MEDIAL</size></b><br><br> 
        <b>Generalidades:</b> Conecta n\xFAcleos vestibulares, oculomotores y cervicales,
        coordinando los movimientos sincronizados de ojos, cabeza y cuello durante
        reflejos visuales y vestibulares.<br><br>  <b>Principales aferencias:</b>
        N\xFAcleos vestibulares y col\xEDculos superiores.<br><br>  <b>Principales
        eferencias:</b> N\xFAcleos oculomotores (III, IV, VI) y asta anterior cervical.<br><br><br> "
      objectReference: {fileID: 0}
