    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>N\xDACLEO CUNEATUS</size></b><br><br>  <b>Generalidades:</b>
        N\xFAcleo lateral al gr\xE1cil que recibe las fibras del fasc\xEDculo cuneatus
        (C2\u2013T6), encargado de transmitir sensibilidad fina, vibraci\xF3n y propiocepci\xF3n
        consciente.<br><br>  <b>Principales aferencias:</b> Neuronas pseudounipolares
        de la m\xE9dula espinal.<br><br>  <b>Principales eferencias:</b> Fibras arcuatas
        internas que cruzan y ascienden como lemnisco medial hacia el VPL del t\xE1lamo.<br><br><br>"
      objectReference: {fileID: 0}
