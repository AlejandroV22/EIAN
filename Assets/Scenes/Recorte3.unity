    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>N\xDACLEO ESPINAL DEL TRIG\xC9MINO</size></b><br><br> 
        <b>Generalidades:</b> N\xFAcleo sensitivo del nervio trig\xE9mino (V) que
        procesa dolor, temperatura y tacto grosero de la cara. Se extiende desde
        el bulbo hasta C3.<br><br>  <b>Principales aferencias:</b> Fibras sensitivas
        de los nervios V, VII, IX y X.<br><br>  <b>Principales eferencias:</b> Lemnisco
        trigeminal hacia el n\xFAcleo ventral posterolateral del t\xE1lamo.<br><br><br>"
      objectReference: {fileID: 0}
