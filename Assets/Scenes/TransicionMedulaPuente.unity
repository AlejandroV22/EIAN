    - target: {fileID: 5597142459016686881, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: infoTexto
      value: "<b><size=120%>FIBRAS CORTICOESPINALES</size></b><br>  <b>Generalidades:</b>
        Axones motores descendentes desde la corteza motora hacia la m\xE9dula espinal.
        No constituyen un n\xFAcleo, sino una v\xEDa motora previamente descrita
        a nivel medular.<br><br>  <b>Principales aferencias:</b> No aplica (son fibras
        descendentes).<br><br>  <b>Principales eferencias:</b> M\xE9dula espinal
        \u2192 motoneuronas alfa y gamma.<br><br><br>"
      objectReference: {fileID: 0}
    - target: {fileID: 7264986227520560567, guid: af52e4441b1b0b44089cfa445ca0cb9e, type: 3}
      propertyPath: m_Name
